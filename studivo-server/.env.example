PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Get from: https://cloud.mongodb.com → Clusters → Connect → Drivers
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/studivo

# Local: redis://localhost:6379 | Azure: from Azure Cache for Redis → Access keys
REDIS_URL=redis://localhost:6379

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=run_the_command_above
JWT_REFRESH_SECRET=run_the_command_again_different_value
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# AI_CACHE_TTL=86400

# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AQ.Ab8RN6...
GEMINI_MODEL=gemini-1.5-flash
AI_CACHE_TTL=86400

# Get from: https://cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Get from: https://app.sendgrid.com → Settings → API Keys → Create API Key (Full Access)
SENDGRID_API_KEY=SG.xxxxxxxx
SENDGRID_FROM_EMAIL=noreply@studivo.com

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AI_RATE_LIMIT_MAX=10

# Google OAuth — from Google Cloud Console https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Amazon PA-API v5 — from https://affiliate-program.amazon.com
AMAZON_PARTNER_TAG=studivo0b-21
AMAZON_HOST=webservices.amazon.eg

# Noon Affiliate — from https://affiliates.noon.com
NOON_AFFILIATE_ID=
NOON_BASE_URL=https://www.noon.com